#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

NEMAC_DIR="/opt/nemac-de"

print_header() {
    clear
    echo -e "${CYAN}"
    echo '  _   _                            ____  _____ '
    echo ' | \ | | ___ _ __ ___   __ _  ___ |  _ \| ____|'
    echo ' |  \| |/ _ \ '\''_ ` _ \ / _` |/ __|| | | |  _|  '
    echo ' | |\  |  __/ | | | | | (_| | (__ | |_| | |___ '
    echo ' |_| \_|\___|_| |_| |_|\__,_|\___||____/|_____|'
    echo -e "${NC}"
    echo ""
}

show_status() {
    local ver="не установлен"
    if [ -f "/etc/nemac" ]; then
        ver=$(grep "Version" /etc/nemac 2>/dev/null | cut -d= -f2)
    fi

    if command -v nemac-session &> /dev/null; then
        echo -e "  Статус: ${GREEN}установлен (v$ver)${NC}"
    else
        echo -e "  Статус: ${RED}не установлен${NC}"
    fi
    echo ""
}

show_menu() {
    while true; do
        print_header
        show_status

        echo -e "  ${GREEN}1${NC})  Переустановить / Обновить"
        echo -e "  ${GREEN}2${NC})  Обновить исходники"
        echo -e "  ${RED}3${NC})  Удалить Nemac DE"
        echo -e "  ${RED}0${NC})  Выход"
        echo ""
        read -rp "  > " choice

        case $choice in
            1)
                echo ""
                echo -e "  ${YELLOW}Запускаю установщик...${NC}"
                curl -fsSL https://raw.githubusercontent.com/lyrka-meow/nemac-de/main/installer.sh -o /tmp/nemac-installer.sh
                sudo bash /tmp/nemac-installer.sh
                rm -f /tmp/nemac-installer.sh
                ;;
            2)
                echo ""
                if [ -d "$NEMAC_DIR/.git" ]; then
                    echo -e "  ${BLUE}Обновляю исходники...${NC}"
                    cd "$NEMAC_DIR" && sudo git pull && echo -e "  ${GREEN}Готово.${NC}" || echo -e "  ${RED}Ошибка.${NC}"
                    echo -e "  ${YELLOW}Для пересборки выберите пункт 1.${NC}"
                else
                    echo -e "  ${RED}Nemac не установлен.${NC}"
                fi
                echo ""
                read -rp "  Нажмите Enter..."
                ;;
            3)
                echo ""
                read -rp "  Удалить Nemac DE? (y/N): " confirm
                if [[ "$confirm" =~ ^[Yy]$ ]]; then
                    curl -fsSL https://raw.githubusercontent.com/lyrka-meow/nemac-de/main/installer.sh -o /tmp/nemac-installer.sh
                    sudo bash /tmp/nemac-installer.sh --uninstall
                    rm -f /tmp/nemac-installer.sh
                fi
                ;;
            0)
                echo ""
                exit 0
                ;;
        esac
    done
}

show_menu
